# Runtime environment mode: development | test | production
APP_ENV=development

# Where simulation exports/scenarios are stored
APP_DATA_DIR=data

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
APP_LOG_LEVEL=INFO

# Pytest subprocess timeout used by src/runner.py
TEST_TIMEOUT_SECONDS=240

# Enable remote telemetry integration (if implemented downstream)
ENABLE_REMOTE_METRICS=false

# Sensitive values: keep empty in source control and set in your secret store
TELEMETRY_API_KEY=
DATABASE_PASSWORD=
